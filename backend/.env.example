NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/liquidnetwork

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# JWT (required — use a long random secret in production)
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=15m

# CORS
# Development: * (reflected as request origin when credentials=true)
# Production: set explicit origin(s), comma-separated — e.g. https://app.liquidnetwork.app
CORS_ORIGIN=*

# Swagger (enabled by default in development)
ENABLE_SWAGGER=true

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Google auth (disabled until implemented)
GOOGLE_AUTH_ENABLED=false
